digraph MergeLogic {
  graph [
    rankdir=LR,
    splines=ortho,
    compound=true,
    nodesep=0.9,
    ranksep=2.0,
    fontname="Helvetica",
    fontsize=10,
    margin=0.3,
    concentrate=false
  ];
  
  node [
    shape=box,
    style="rounded,filled",
    penwidth=1.2,
    fontname="Helvetica",
    fontsize=10,
    fillcolor=lightblue,
    color=steelblue,
    margin="0.12,0.08"
  ];
  
  edge [
    fontname="Helvetica",
    fontsize=9,
    color=darkgray,
    penwidth=1.0,
    minlen=1.0
  ];

  // ══════════════════════════════════════════════════════════════
  // INPUT FROM DRAM
  // ══════════════════════════════════════════════════════════════
  
  dram_input [
    label="Read Data Path\n(DRAM)\n────────────\n{tag, data[63:0]}",
    fillcolor="#FFF8E1",
    color="#F57F17",
    width=1.8,
    height=0.95
  ];

  // ══════════════════════════════════════════════════════════════
  // MERGE LOGIC CLUSTER
  // ══════════════════════════════════════════════════════════════
  
  subgraph cluster_merge {
    style="rounded,filled";
    color="#FF6F00";
    fillcolor="#FFF3E0";
    penwidth=2.0;
    label="Merge Logic";
    fontname="Helvetica";
    fontsize=10;
    fontcolor="#FF6F00";
    labeljust=l;
    margin=0.3;
    
    // Block 1: Tag Decoder
    tag_decoder [
      label="Tag Decoder\n────────────\nextracts:\naxid, orig_id\nfrag_idx[3:0]\nfrag_total[3:0]\n────────────\n{axid, orig_id,\nfrag_idx,\nfrag_total,\ndata}",
      fillcolor="#E8F5E9",
      color="#388E3C",
      penwidth=1.2,
      width=1.8,
      height=1.5
    ];
    
    // Block 3: Reassembly Tracker (positioned above Fragment Buffer)
    reassembly_tracker [
      label="Reassembly Tracker\n─────────────────\nfrag_count[axid]\nexpected[axid]\n─────────────────\nexpected =\nfrag_total\n(latched on\nfirst frag)",
      fillcolor="#F3E5F5",
      color="#6A1B9A",
      penwidth=1.2,
      width=1.7,
      height=1.5
    ];
    
    // Block 2: Fragment Buffer
    frag_buffer [
      label="Fragment Buffer\n────────────────\n[axid][frag_idx]\n{data, valid}",
      fillcolor="#E0F2F7",
      color="#0277BD",
      penwidth=1.2,
      width=1.6,
      height=1.0
    ];
    
    // Block 4: Output Mux
    output_mux [
      label="Output Mux\n────────────────\nreads fragments\nin frag_idx order\n(0 .. frag_total-1)\nConcatenates\ninto burst",
      fillcolor="#FFE0B2",
      color="#E65100",
      penwidth=1.2,
      width=1.7,
      height=1.4
    ];
  }

  // ══════════════════════════════════════════════════════════════
  // OUTPUT TO ROB
  // ══════════════════════════════════════════════════════════════
  
  rob_output [
    label="ROB\n(Tag Lookup &\nFill)\n────────────\n{axid,\ndata_burst\n[N*64-1:0]}",
    fillcolor="#E0F2F7",
    color="#0277BD",
    width=1.8,
    height=1.0
  ];

  // ══════════════════════════════════════════════════════════════
  // CONNECTIONS
  // ══════════════════════════════════════════════════════════════
  
  // Input from DRAM to Tag Decoder
  dram_input -> tag_decoder [
    color="#F57F17",
    weight=10
  ];
  
  // Bypass path for frag_total = 1 (no buffering)
  dram_input -> output_mux [
    style=dashed,
    xlabel="frag_total = 1\n(no buffering)",
    color="#FF6F00",
    weight=1,
    minlen=5,
    constraint=false,
    arrowhead=vee,
    arrowtail=none
  ];
  
  // Tag Decoder to Fragment Buffer
  tag_decoder -> frag_buffer [
    xlabel="write fragment",
    color="#388E3C",
    weight=10
  ];
  
  // Tag Decoder to Reassembly Tracker (frag_total signal)
  tag_decoder -> reassembly_tracker [
    xlabel="frag_total",
    color="#388E3C",
    weight=2,
    constraint=false
  ];
  
  // Tag Decoder to Reassembly Tracker (fragment ID tracking)
  tag_decoder -> reassembly_tracker [
    xlabel="{axid, frag_idx}",
    color="#388E3C",
    weight=2,
    constraint=false
  ];
  
  // Fragment Buffer to Output Mux
  frag_buffer -> output_mux [
    color="#0277BD",
    weight=10
  ];
  
  // Burst complete trigger from Reassembly Tracker to Output Mux
  reassembly_tracker -> output_mux [
    style=dashed,
    xlabel="burst_complete[axid]",
    color="#FF6F00",
    weight=2,
    constraint=false
  ];
  
  // Output Mux to ROB
  output_mux -> rob_output [
    xlabel="data_burst",
    color="#E65100",
    weight=10
  ];

  // ══════════════════════════════════════════════════════════════
  // RANK CONSTRAINTS
  // ══════════════════════════════════════════════════════════════
  
}
