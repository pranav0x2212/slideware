\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Address Translator pipeline. The Bit Field Extractor decodes the byte address into DRAM fields according to the configured memory map; the CMD Builder packs extracted fields with AXI metadata to form the final command packet.}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:addr_translator}{{5}{4}{Address Translator pipeline. The Bit Field Extractor decodes the byte address into DRAM fields according to the configured memory map; the CMD Builder packs extracted fields with AXI metadata to form the final command packet}{figure.caption.4}{}}
