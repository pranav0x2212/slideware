\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Internal architecture of the Reorder Buffer (ROB). The ROB reconstructs AXI read responses from potentially out-of-order DRAM returns while preserving per-AXID ordering.}}{3}{figure.caption.3}\protected@file@percent }
\newlabel{fig:rob_arch}{{4}{3}{Internal architecture of the Reorder Buffer (ROB). The ROB reconstructs AXI read responses from potentially out-of-order DRAM returns while preserving per-AXID ordering}{figure.caption.3}{}}
